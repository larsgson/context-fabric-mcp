# API key for authenticating client requests (leave empty to allow all)
API_KEY=

# Groq API key — primary provider for chat endpoints (free tier).
# Get one at https://console.groq.com/keys
GROQ_API_KEY=

# OpenAI API key — optional fallback if Groq is rate-limited/unavailable.
# Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Max OpenAI fallback requests per day (safety cap to prevent surprise bills).
# Default: 50. Set to 0 to disable the fallback entirely.
OPENAI_FALLBACK_DAILY_LIMIT=50

# Optional model overrides
# GROQ_MODEL=llama-3.3-70b-versatile
# OPENAI_MODEL=gpt-4o-mini

# Server port (default: 8000)
PORT=8000

# Quiz storage directory (default: ./quizzes)
# QUIZ_DIR=./quizzes
